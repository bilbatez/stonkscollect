# Copy to .env (cp .env.example .env) and edit. Real env vars override these.

# Local libSQL/SQLite file (dev fallback). Relative paths are from where you run
# the binary (backend/).
DATABASE_URL=sqlite://../data/stonks.db

# Turso (remote libSQL). When TURSO_DATABASE_URL is set it is used instead of
# DATABASE_URL; the token is required. Leave blank for a local file.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# SEC requires a descriptive User-Agent with contact info.
# Quote values containing spaces — dotenv aborts the whole file on an unquoted
# value with a space, silently leaving every later var (COLLECT_ALL, etc.) unset.
USER_AGENT="stonkscollect you@example.com"

# REST API port (serve).
PORT=8080

# Tickers used by `collect` when no --ticker flags are given.
TICKERS=AAPL,MSFT,GOOG

# Collect the entire bootstrapped US universe (~10k companies) instead of a
# ticker list. Overrides TICKERS. Each company pulls EDGAR facts + Yahoo prices
# + Yahoo news (+ FMP/Finnhub if keyed).
COLLECT_ALL=false

# Per-HOST request spacing in ms (EDGAR, Yahoo and each vendor throttle
# independently). 150ms ≈ 6 req/s per host. SEC allows ~10 req/s, so 120 is
# safe for EDGAR; Yahoo is unofficial — go lower at your own risk of 429s.
# Lowering this is the biggest speedup lever (more than threads).
REQUEST_DELAY_MS=150

# Incremental collection: skip companies whose fundamentals were collected
# within this many hours. Unset = always recollect. e.g. 168 = weekly.
# Use this to resume a big run without re-fetching what's fresh.
# COLLECT_MAX_AGE_HRS=168

# Companies fetched concurrently in bulk collection. With per-host limiters,
# raising this parallelizes across EDGAR/Yahoo/vendors. Default 8; try 16–32
# for a faster full pass (paired with a lower REQUEST_DELAY_MS).
COLLECT_CONCURRENCY=8

# Cross-source discrepancy threshold (relative). Default 0.05 = 5%.
RECONCILE_THRESHOLD=0.05

# Graham "adequate size" revenue floor (USD). Default 500M.
GRAHAM_MIN_REVENUE=500000000

# Where the weekly Parquet tier writes one prices file per ticker (serve).
PARQUET_DIR=../data/parquet

# Optional extra sources — leave blank to skip.
FMP_API_KEY=
FINNHUB_API_KEY=
